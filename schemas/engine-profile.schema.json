{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/emirhhan/alltaskfiles/schemas/engine-profile.schema.json",
  "title": "Fusion Game Engine Profile",
  "description": "Motor profili şeması. engine-profiles/**/*.yaml dosyaları için doğrulama şeması.",
  "type": "object",
  "required": ["engine", "display_name", "current_stable", "latest_checked", "license", "language", "official_docs", "supported_platforms"],
  "additionalProperties": false,
  "properties": {
    "engine": {
      "type": "string",
      "enum": ["godot", "phaser"]
    },
    "display_name": { "type": "string" },
    "current_stable": {
      "type": "string",
      "description": "Şu an önerilen kararlı sürüm (örn '4.7.1', '3.90.0')."
    },
    "latest_checked": { "type": "string" },
    "release_model": { "type": "string" },
    "license": { "type": "string" },
    "language": { "type": "string" },
    "alt_languages": {
      "type": "array",
      "items": { "type": "string" }
    },
    "official_docs": {
      "type": "string",
      "format": "uri"
    },
    "supported_platforms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "web_export": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "runtime": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "windows_build": { "type": "object" },
    "strengths": { "type": "array", "items": { "type": "string" } },
    "weaknesses": { "type": "array", "items": { "type": "string" } },
    "best_for": { "type": "array", "items": { "type": "string" } },
    "recipe_coverage": { "type": "string" },
    "template_coverage": { "type": "string" }
  }
}
