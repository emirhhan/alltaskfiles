{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/emirhhan/alltaskfiles/schemas/recipe.schema.json",
  "title": "Fusion Game Recipe",
  "description": "Recipe (yeniden kullanılabilir oyun sistemi tarifi) şeması. recipes/**/*.yaml dosyaları için doğrulama şeması.",
  "type": "object",
  "required": ["recipe", "engine", "engine_version", "language", "description", "official_source", "steps", "validation"],
  "additionalProperties": false,
  "properties": {
    "recipe": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Benzersiz recipe kimliği (örn godot_character_movement)."
    },
    "engine": {
      "type": "string",
      "enum": ["godot", "phaser"]
    },
    "engine_version": {
      "type": "string",
      "description": "Hedef motor sürümü (örn '4.x', '3.90.0')."
    },
    "language": {
      "type": "string",
      "enum": ["gdscript", "javascript", "typescript", "csharp"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "official_source": {
      "type": "string",
      "format": "uri",
      "description": "Resmî docs URL'si (kaynak güven politikası Bölüm 7)."
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "detail"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "code_snippet": { "type": "string" },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
